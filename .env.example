# ============================================================
# Şoför Takip — Environment Variables
# ============================================================
# Bu dosyayı kopyalayıp ".env" adıyla kaydedin ve değerleri doldurun.
# .env dosyası git'e gitmez (.gitignore'da).
# Production'da (Railway/Vercel) bu değerleri panel üzerinden girin.
# ============================================================

# Supabase — ZORUNLU
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOi...

# Arvento — OPSİYONEL (boş bırakırsanız simulation modunda çalışır)
ARVENTO_API_URL=https://web.arvento.com/rest
ARVENTO_API_KEY=

# Polling aralığı (saniye) — OPSİYONEL (default: 30)
LOCATION_POLL_SECONDS=30
